<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="#111111">

    <RelativeLayout
        android:id="@+id/circle_container"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="4dp">

        <ImageView
            android:id="@+id/widget_circle_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/widget_circle" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_db_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- dB"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/widget_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="STANDBY"
                android:textColor="#00E5FF"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/circle_container"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="14dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TIME : " android:textSize="10sp" android:textColor="#888888" />
            <TextView android:id="@+id/widget_time_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0h 0m" android:textSize="12sp" android:textColor="#DDDDDD" android:fontFamily="monospace" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AVG : " android:textSize="10sp" android:textColor="#888888" />
            <TextView android:id="@+id/widget_avg_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- dB" android:textSize="12sp" android:textColor="#DDDDDD" android:fontFamily="monospace" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_device_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="未接続"
        android:textColor="#666666"
        android:textSize="9sp"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end" />

</RelativeLayout>